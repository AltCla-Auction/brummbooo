# Firebase Client (公開可能)
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=brummbooo.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=brummbooo
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=brummbooo.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# Firebase Admin (サーバーサイドのみ)
FIREBASE_PROJECT_ID=brummbooo
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@brummbooo.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# Resend (for contact form)
RESEND_API_KEY=your-resend-api-key
CONTACT_EMAIL=info@brummbooo.auto

# Admin Auth (簡易認証用)
ADMIN_EMAIL=admin@brummbooo.auto
